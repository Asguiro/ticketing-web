# true = données mock locales (sans API backend)
# false = appels réels vers ticketing-api (recommandé en local)
MOCK_API=false

# URL de l'API backend (utilisée quand MOCK_API=false)
API_URL=http://localhost:3000/api/v1

# Secret pour signer les cookies de session SSR
SESSION_SECRET=change-me-with-a-strong-secret
